# Claude Code UI Environment Configuration
# Only includes variables that are actually used in the code

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Backend server port (Express API + WebSocket server)
#API server
PORT=3001
#Frontend port
VITE_PORT=5173

# Optional SSH configuration for remote Claude sessions
# When provided, UI will send these credentials to the server
# to execute Claude CLI on the remote host
VITE_SSH_HOST=
VITE_SSH_PORT=
VITE_SSH_USER=
VITE_SSH_PASSWORD=
VITE_SSH_PRIVATE_KEY=